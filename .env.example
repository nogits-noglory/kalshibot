# Kalshi API credentials
# Get your API key and RSA private key from https://kalshi.com/account/api
KALSHI_API_KEY=your-kalshi-api-key-here
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private_key.pem

# Optional: override the default bot working directory
# KALSHI_BOT_DIR=/path/to/kalshibot

# Anthropic API key (required for the agent)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: ntfy.sh topic for push notifications
# Create a topic at https://ntfy.sh
NTFY_TOPIC=your-ntfy-topic

# Optional: GitHub Gist for remote status reporting
GITHUB_GIST_TOKEN=your-github-token
GITHUB_GIST_ID=your-gist-id
